# Caracal Environment Variables Template
# Copy this file to .env and update with your actual values
# NEVER commit the .env file with actual credentials

# Application Settings
CARACAL_APP_NAME=caracal
CARACAL_APP_VERSION=0.1.0
CARACAL_APP_ENVIRONMENT=development
CARACAL_APP_DEBUG=true

# Server Settings
CARACAL_SERVER_HOST=localhost
CARACAL_SERVER_PORT=8080
CARACAL_SERVER_READ_TIMEOUT=30
CARACAL_SERVER_WRITE_TIMEOUT=30

# Logging Settings
CARACAL_LOGGING_LEVEL=info
CARACAL_LOGGING_FORMAT=text
CARACAL_LOGGING_CONSOLE=true

# Database Settings
CARACAL_DATABASE_TYPE=postgres
CARACAL_DATABASE_HOST=localhost
CARACAL_DATABASE_PORT=5432
CARACAL_DATABASE_NAME=caracal
CARACAL_DATABASE_USER=caracal
CARACAL_DATABASE_PASSWORD=your_secure_password_here
CARACAL_DATABASE_SSL_MODE=prefer

# Cache Settings
CARACAL_CACHE_BACKEND=redis
CARACAL_CACHE_TTL=3600

# Redis Settings (if using Redis cache)
CARACAL_REDIS_HOST=localhost
CARACAL_REDIS_PORT=6379
CARACAL_REDIS_DB=0
CARACAL_REDIS_PASSWORD=your_redis_password

# Security Settings
CARACAL_SECURITY_JWT_SECRET_KEY=your_jwt_secret_key_here
CARACAL_SECURITY_JWT_EXPIRATION=3600
CARACAL_SECURITY_JWT_ALGORITHM=HS256

# API Settings
CARACAL_API_RATE_LIMIT_ENABLED=false
CARACAL_API_RATE_LIMIT_RPS=100

# Features
CARACAL_FEATURES_ALPHA_FEATURES=false
CARACAL_FEATURES_EXPERIMENTAL_ENDPOINTS=false
CARACAL_FEATURES_METRICS=true
CARACAL_FEATURES_HEALTH_CHECKS=true

# Monitoring
CARACAL_MONITORING_METRICS_ENABLED=true
CARACAL_MONITORING_METRICS_PORT=9090
CARACAL_MONITORING_TRACING_ENABLED=false
CARACAL_MONITORING_TRACING_SAMPLE_RATE=0.1

